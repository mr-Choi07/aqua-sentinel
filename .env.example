# 국립수산과학원(NIFS) Open API 키 — 서비스마다 키가 다르므로 분리해서 관리
# 실시간어장정보 API 키
NIFS_TEMP_API_KEY=
# 적조정보 API 키
NIFS_REDTIDE_API_KEY=

# Anthropic API 키 (RAG 대응 코치 + 폐사 사진 분석용)
ANTHROPIC_API_KEY=
# (선택) 나중에 Postgres로 전환할 경우 사용할 DB 접속 URL
# DATABASE_URL=postgresql://user:password@localhost:5432/aqua_sentinel

# 웹 푸시 알림용 VAPID 키 쌍 — `python -m pipeline.push` 실행해서 한 번만 생성하고
# 이후 계속 같은 값을 쓴다(키가 바뀌면 기존에 구독한 브라우저가 전부 무효화됨).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# 웹 푸시 표준(RFC 8030)이 요구하는 연락처 — 실제 발송 여부와 무관하게 필요
VAPID_CONTACT_EMAIL=mailto:example@example.com
